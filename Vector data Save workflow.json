    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const fileName = $input.item.json.name || 'unknown';\nconst updatedDate = $input.item.json.modifiedTime || new Date().toISOString();\n\n// Categorize based on filename keywords\nlet category = 'company';\nconst lowerName = fileName.toLowerCase();\nif (lowerName.includes('career') || lowerName.includes('job') || lowerName.includes('hiring') || lowerName.includes('opening') || lowerName.includes('position')) {\n  category = 'jobs';\n}\n\nreturn {\n  json: {\n    fileName: fileName,\n    updatedDate: updatedDate,\n    category: category\n  },\n  binary: $input.item.binary\n};"
      },
      "id": "2302f401-f296-4bb8-a149-bf59593ebabb",
      "name": "Add Metadata & Categorize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -176,
        -112
      ]
    },
    {
      "parameters": {
